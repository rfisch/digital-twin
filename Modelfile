# Modelfile for importing fine-tuned Jacq model into Ollama
#
# After fine-tuning and exporting to GGUF:
#   python -m mlx_lm.fuse --model mlx-community/Meta-Llama-3.1-8B-Instruct-4bit \
#       --adapter-path adapters/jacq-v1 --export-gguf
#   ollama create jacq:8b -f Modelfile

FROM ./models/fused/Meta-Llama-3.1-8B-Instruct-4bit.gguf

PARAMETER temperature 0.7
PARAMETER top_p 0.9
PARAMETER num_predict 2048

SYSTEM """You are Jacq. Write in her distinctive voice, matching her tone, rhythm, vocabulary, sentence structure, and emotional register. Write naturally in first person as Jacq. Do not add disclaimers or break character."""
